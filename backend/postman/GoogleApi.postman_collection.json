    {
      "name": "OAuth",
      "item": [
        {
          "name": "Start Google OAuth",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/google-api/authorize?scopes={{scopes}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "google-api",
                "authorize"
              ],
              "query": [
                {
                  "key": "scopes",
                  "value": "{{scopes}}"
                }
              ]
            },
            "description": "Starts OAuth by redirecting to Google. Run this in a browser-capable Postman flow or open the same URL in your browser."
          },
          "response": []
        },
        {
          "name": "OAuth Callback",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/google-api/redirection?code=sample-code&state=sample-state",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "google-api",
                "redirection"
              ],
              "query": [
                {
                  "key": "code",
                  "value": "sample-code"
                },
                {
                  "key": "state",
                  "value": "sample-state"
                }
              ]
            },
            "description": "Google redirects here after consent. Do not call manually unless you are replaying a real callback."
          },
          "response": []
        },
        {
          "name": "Token Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/google-api/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "google-api",
                "token"
              ]
            },
            "description": "Shows whether a Google OAuth token has been stored locally."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Google API",
      "item": [
        {
          "name": "Google API Proxy Call",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"{{googleApiUrl}}\",\n  \"method\": \"{{googleApiMethod}}\",\n  \"body\": {{googleApiBody}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/google-api/call",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "google-api",
                "call"
              ]
            },
            "description": "Uses the locally stored Google access token to call any Google REST API URL."
          },
          "response": []
        }
      ]
    },
